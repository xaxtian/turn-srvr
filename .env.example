# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Clave que deben enviar los clientes (chat-server) para obtener credenciales.
# Genera con: openssl rand -hex 32
SERVICE_API_KEY=genera_con_openssl_rand_-hex_32

# Orígenes permitidos para CORS (separados por coma)
# En producción: solo la URL del chat-server
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5173

# ─── TURN Server ─────────────────────────────────────────────────────────────
# Dominio o IP pública del servidor coturn
TURN_SERVER_HOST=turn.tudominio.com

# Puertos del servidor TURN
TURN_PORT=3478
TURNS_PORT=5349

# Secreto compartido entre este servicio y coturn.
# DEBE ser idéntico al valor de "static-auth-secret" en turnserver.conf
# Genera con: openssl rand -hex 32
TURN_SECRET=genera_con_openssl_rand_-hex_32

# Tiempo de validez de las credenciales en segundos (default: 86400 = 24h)
TURN_TTL=86400
